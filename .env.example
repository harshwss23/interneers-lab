# InterneersLab Environment Configuration Template
# Copy this file to .env and fill in your details

# Database Settings (Overridden by docker-compose for internal networking)
MONGO_DB=interneers_lab
MONGO_HOST=mongodb
MONGO_PORT=27017

# Email Settings (SMTP - Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Django Security
DEBUG=False
SECRET_KEY=change-me-to-a-secure-random-string
ALLOWED_HOSTS=*
